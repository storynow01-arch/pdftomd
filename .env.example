# ============================================================
# 行事曆解析系統 - 環境變數範本
# 複製此檔案為 .env.local 並填入您的 API Key
# ============================================================

# Gemini API（PDF 解析核心）
# 申請：https://aistudio.google.com/apikey
# 支援填寫多組 API Key 進行輪詢，請使用半形逗號 `,` 隔開，例如：key1,key2,key3
GEMINI_API_KEY=

# 選擇要使用的 Gemini 模型（選填，預設為 gemini-3-flash-preview）
# 可用模型參考：gemini-3-flash-preview, gemini-2.5-flash, gemini-flash-latest
GEMINI_MODEL=gemini-3-flash-preview

# Notion 整合
# Token 申請：https://www.notion.so/my-integrations
# 建立 Integration → 複製 Internal Integration Token
NOTION_TOKEN=
# 目標 Page ID（從 Notion Page URL 取得，32位英數字）
NOTION_PAGE_ID=

# Google Apps Script Calendar
# 詳見 gas/README.md 的部署步驟
GAS_CALENDAR_URL=
# 自訂隨機密鑰（用來驗證請求來源，自己取一串隨機字串）
GAS_SECRET_KEY=

# LINE Bot（最後階段再設定）
LINE_CHANNEL_TOKEN=
LINE_CHANNEL_SECRET=

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
